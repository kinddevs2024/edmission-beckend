# Server
NODE_ENV=development
PORT=4000
# HOST: адрес для прослушивания (0.0.0.0 — все интерфейсы, для проверки здоровья снаружи)
HOST=0.0.0.0

# Database (MongoDB). Локальный сервер: база "edmission" в своём кластере.
# Пример для сервера с локальным MongoDB: mongodb://localhost:27017/edmission
MONGODB_URI=mongodb+srv://kinddevs2024_db_user:vKXsQ7GDxWrJt5U0@unistem.lfu0tc5.mongodb.net/UNISTEM2026?retryWrites=true&w=majority

# Google OAuth (регистрация / вход через Google). Тот же Client ID, что на фронте.
# Можно задать здесь GOOGLE_CLIENT_ID или только в edmission-front/.env как VITE_GOOGLE_CLIENT_ID — бэкенд подхватит (файл фронта подгружается без перезаписи ваших ключей).
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# Для мобильного приложения (Expo): те же ID, что в EXPO_PUBLIC_* — иначе verify id_token не пройдёт.
# GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com

# Yandex OAuth (https://oauth.yandex.ru). Для SDK-кнопки: Redirect URI https://ваш-домен/suggest/token.html (локально: http://localhost:5173/suggest/token.html). Опционально также /auth/yandex/callback для старого потока.
# Client ID можно продублировать во фронте как VITE_YANDEX_CLIENT_ID.
# YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET=

# Публичный URL фронта — для проверки redirect_uri при обмене кода (должен совпадать с origin в callback).
# FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS (comma-separated origins). Пустое значение = встроенный список по умолчанию (не оставляйте CORS_ORIGIN= без доменов).
# В NODE_ENV=development дополнительно разрешены: localhost/127.0.0.1/10.0.2.2 (любой порт), частные LAN 192.168.x.x и 10.x.x.x, *.exp.direct.
# Добавьте сюда точный origin WebView/Expo Web, если открываете фронт с другого хоста (например http://192.168.1.5:5173).
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:8081,http://localhost:19006,https://edmission.uz,https://www.edmission.uz

# AI ассистент: выбери один вариант (первый имеет приоритет)
# 1) OpenAI (ChatGPT)
OPENAI_API_KEY=sk-proj-xxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# 2) Google Gemini (бесплатный тир: https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxx

# 3) DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# Опционально: модель (по умолчанию deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# За reverse proxy (nginx, Cloudflare): реальный IP клиента для rate limit
# TRUST_PROXY=1

# Rate limits: в production включены по умолчанию (глобальный /api, auth, поиск, upload).
# В development выключены; чтобы тестировать лимиты локально: ENABLE_RATE_LIMIT_IN_DEV=true
# Полное отключение (только осознанно, напр. нагрузочные тесты): DISABLE_RATE_LIMIT=true
# ENABLE_RATE_LIMIT_IN_DEV=true
# DISABLE_RATE_LIMIT=true
# JSON_BODY_LIMIT=1mb
# RATE_LIMIT_GLOBAL_MAX_PER_MINUTE=400
# RATE_LIMIT_AUTH_MAX_PER_15MIN=60
# RATE_LIMIT_SEARCH_PER_MINUTE=60
# RATE_LIMIT_UPLOAD_MAX_PER_15MIN=40
# RATE_LIMIT_UPLOAD_AUTH_MAX_PER_15MIN=200
# RATE_LIMIT_PUBLIC_VISIT_PER_MINUTE=120

# Response compression (gzip): on in production unless DISABLE_RESPONSE_COMPRESSION=true; optional in dev: ENABLE_RESPONSE_COMPRESSION=true
# DISABLE_RESPONSE_COMPRESSION=true
# ENABLE_RESPONSE_COMPRESSION=true

# express-slow-down (per IP, 15m window) — delay ramps after SLOW_DOWN_DELAY_AFTER requests
# SLOW_DOWN_DELAY_AFTER=250
# SLOW_DOWN_DELAY_STEP_MS=100
# SLOW_DOWN_MAX_DELAY_MS=10000

# connect-timeout — production default 120s; 0 = off. Skips multipart + /api/payment/webhook
# API_REQUEST_TIMEOUT_MS=120000
# DISABLE_API_REQUEST_TIMEOUT=true

# Лимиты и таймаут (для DeepSeek и Ollama)
AI_CHAT_RATE_LIMIT_PER_MINUTE=10
AI_CHAT_TIMEOUT_MS=60000

# Если DEEPSEEK_API_KEY не задан — используется Ollama (локально)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:1.5b

# Email: SendGrid или Gmail SMTP
# Для Gmail: EMAIL_ENABLED=true + SMTP_* + App Password (myaccount.google.com/apppasswords)
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Uploads (local path or S3)
UPLOAD_DIR=./uploads

