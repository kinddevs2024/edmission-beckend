# Server
NODE_ENV=development
PORT=4000
# HOST: адрес для прослушивания (0.0.0.0 — все интерфейсы, для проверки здоровья снаружи)
HOST=0.0.0.0

# Database (MongoDB). Локальный сервер: база "edmission" в своём кластере.
# Пример для сервера с локальным MongoDB: mongodb://localhost:27017/edmission
MONGODB_URI=mongodb://localhost:27017/edmission

# Google OAuth (регистрация / вход через Google). Тот же Client ID, что на фронте.
# Можно задать здесь GOOGLE_CLIENT_ID или только в edmission-front/.env как VITE_GOOGLE_CLIENT_ID — бэкенд подхватит (файл фронта подгружается без перезаписи ваших ключей).
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Yandex OAuth (https://oauth.yandex.ru). Для SDK-кнопки: Redirect URI https://ваш-домен/suggest/token.html (локально: http://localhost:5173/suggest/token.html). Опционально также /auth/yandex/callback для старого потока.
# Client ID можно продублировать во фронте как VITE_YANDEX_CLIENT_ID.
# YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET=

# Публичный URL фронта — для проверки redirect_uri при обмене кода (должен совпадать с origin в callback).
# FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS (comma-separated origins). Локально: http://localhost:8080. Продакшен: https://edmission.uz, https://www.edmission.uz
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:8080,https://edmission.uz,https://www.edmission.uz

# AI ассистент: выбери один вариант (первый имеет приоритет)
# 1) OpenAI (ChatGPT)
OPENAI_API_KEY=sk-proj-xxxxxxxx

# 2) Google Gemini (бесплатный тир: https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxx

# 3) DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# Опционально: модель (по умолчанию deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# Лимиты и таймаут (для DeepSeek и Ollama)
AI_CHAT_RATE_LIMIT_PER_MINUTE=10
AI_CHAT_TIMEOUT_MS=60000

# Если DEEPSEEK_API_KEY не задан — используется Ollama (локально)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:1.5b

# Email: SendGrid или Gmail SMTP
# Для Gmail: EMAIL_ENABLED=true + SMTP_* + App Password (myaccount.google.com/apppasswords)
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Uploads (local path or S3)
UPLOAD_DIR=./uploads
